# Copy to .env and adjust values for your deployment.

# TCP port the server listens on (default: 3001)
PORT=3001

# How long to keep spreadsheet data in memory before re-fetching (ms).
# 600000 = 10 minutes (default)
CACHE_TTL_MS=600000

# Public URL of the web app — used in the <link> element of the RSS channel.
FEED_BASE_URL=https://www.rauljimenez.info/esridevs-social-activity/

# Public URL of THIS server — used in the atom:link self-reference.
# Set this when deployed so RSS readers can find the feed.
RSS_SERVER_URL=http://localhost:3001

# Max items returned per feed request (default: 100)
MAX_ITEMS=100
